{
  "name": "agent-wallet",
  "version": "0.0.1",
  "private": true,
  "description": "Policy-governed payment wallet for autonomous agents — x402 crypto and Stripe fiat rails behind one trust boundary.",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "demo": "node src/demo.ts",
    "dev": "node --watch src/demo.ts",
    "mcp": "node src/mcp-main.ts",
    "mcp:check": "node src/mcp-smoketest.ts",
    "custody:address": "node src/custody-init.ts",
    "x402:resource": "node src/x402-test-resource.ts",
    "x402:check": "node src/x402-smoketest.ts",
    "control:check": "node src/control-smoketest.ts",
    "start": "node dist/index.js"
  },
  "keywords": [
    "agent",
    "wallet",
    "x402",
    "ap2",
    "payments",
    "mcp"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@coinbase/cdp-sdk": "^1.49.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@x402/core": "^2.12.0",
    "@x402/evm": "^2.12.0",
    "@x402/express": "^2.12.0",
    "@x402/fetch": "^2.12.0",
    "express": "^5.2.1",
    "stripe": "^22.1.1",
    "viem": "^2.49.3",
    "zod": "^4.4.3"
  }
}
